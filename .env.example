# Supabase 설정
# https://supabase.com 에서 프로젝트를 생성한 후
# Settings → API에서 확인할 수 있습니다.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Cloudinary 사진 저장소 설정 (무료: 25GB 저장/25GB 대역폭)
# 1. https://cloudinary.com 에서 무료 계정 생성
# 2. Dashboard에서 Cloud Name 확인
# 3. Settings → Upload → Upload presets에서 "Unsigned" preset 생성
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-unsigned-preset

# 이메일 초대 알림 설정 (선택)
# Supabase Edge Function + Resend 연동
# 1. Resend (https://resend.com)에서 무료 계정 생성 후 API 키 발급
# 2. supabase secrets set RESEND_API_KEY=re_xxxxxxx
# 3. supabase functions deploy send-share-email
# 설정하지 않으면 이메일 알림 없이 앱 내 알림만 동작합니다

# Supabase, Cloudinary 모두 설정하지 않으면 데모 모드로 동작합니다 (샘플 데이터 + localStorage)
